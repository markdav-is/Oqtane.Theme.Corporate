<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="CopyOqtaneThemeCorporateAssets" AfterTargets="Build">
    <ItemGroup>
      <_ThemeAssets Include="$(MSBuildThisFileDirectory)..\wwwroot\**\*.*" />
    </ItemGroup>
    <Copy
      SourceFiles="@(_ThemeAssets)"
      DestinationFiles="@(_ThemeAssets->'$(MSBuildProjectDirectory)\wwwroot\%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true" />
  </Target>
</Project>
